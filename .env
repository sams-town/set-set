CI_ENVIRONMENT = development

app.baseURL     = 'http://localhost:8080/'
app.appName     = 'RS.Taman Harapan Baru'
app.appTimezone = 'Asia/Jakarta'

database.default.hostname = localhost
database.default.database = rsthbid_asset_tb
database.default.username = rsthbid_user_as
database.default.password = samboja90
database.default.DBDriver = MySQLi
database.default.DBPrefix  =
database.default.port      = 3306

session.driver      = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.savePath    = 'ci_sessions'
session.expiration  = 7200
session.cookieName  = ci_session
session.matchIP     = false
session.DBGroup     = default

# ── WhatsApp Gateway ─────────────────────────────────────────
wa.gateway_url   = https://api.fonnte.com/send
wa.token         = YOUR_API_TOKEN_HERE
wa.enabled       = false
wa.admin_numbers = 628123456789
wa.curl_timeout  = 5
